#include <Adafruit_GFX.h>
#include <Adafruit_ST7735.h>

#define TFT_CS   2
#define TFT_DC   33
#define TFT_MOSI 12
#define TFT_SCLK 13
#define TFT_RST  -1

Adafruit_ST7735 tft = Adafruit_ST7735(TFT_CS, TFT_DC, TFT_MOSI, TFT_SCLK, TFT_RST);

void setup() {
  Serial.begin(115200);
  delay(200);

  Serial.println("=== TFT TEST ONLY (NO WIFI / NO CAMERA) ===");

  tft.initR(INITR_BLACKTAB);
  tft.setRotation(1);
  tft.fillScreen(ST77XX_BLACK);
  tft.setTextColor(ST77XX_WHITE);
  tft.setTextSize(2);
  tft.setCursor(0, 20);
  tft.println("THIS MY SHIT");
}

void loop() {
  Serial.println("TFT TEST LOOP ALIVE");
  delay(1000);
}
