#include <ESP32Servo.h>

#define SERVO_PIN 14   // change if needed
#define SERVO_REST 10
#define SERVO_PRESS 100

Servo s;

void setup() {
  Serial.begin(115200);
  s.setPeriodHertz(50);
  s.attach(SERVO_PIN, 500, 2400);
  Serial.println("Servo test: moving...");
}

void loop() {
  s.write(SERVO_REST);
  delay(1000);
  s.write(SERVO_PRESS);
  delay(1000);
}
