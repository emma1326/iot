void setup() {
  Serial.begin(115200);
  delay(200);

  pinMode(PIR_PIN, INPUT);

  // Servo
  sprayServo.setPeriodHertz(50);
  sprayServo.attach(SERVO_PIN, 500, 2400);
  sprayServo.write(SERVO_REST);

  // TFT (ST7789)
  tft.init(128, 160);
  tft.setRotation(1);
  tftMsg("READY", "MOVE=PHOTO");

  Serial.println("\nStarting...");

  // WiFi
  WiFi.begin(ssid, password);
  WiFi.setSleep(false);

  Serial.print("Connecting to WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connected");
  Serial.print("IP: ");
  Serial.println(WiFi.localIP());

  // Camera config (same as your working version)
  camera_config_t config;
  config.ledc_channel = LEDC_CHANNEL_0;
  config.ledc_timer   = LEDC_TIMER_0;

  config.pin_d0 = Y2_GPIO_NUM;
  config.pin_d1 = Y3_GPIO_NUM;
  config.pin_d2 = Y4_GPIO_NUM;
  config.pin_d3 = Y5_GPIO_NUM;
  config.pin_d4 = Y6_GPIO_NUM;
  config.pin_d5 = Y7_GPIO_NUM;
  config.pin_d6 = Y8_GPIO_NUM;
  config.pin_d7 = Y9_GPIO_NUM;

  config.pin_xclk  = XCLK_GPIO_NUM;
  config.pin_pclk  = PCLK_GPIO_NUM;
  config.pin_vsync = VSYNC_GPIO_NUM;
  config.pin_href  = HREF_GPIO_NUM;

  config.pin_sccb_sda = SIOD_GPIO_NUM;
  config.pin_sccb_scl = SIOC_GPIO_NUM;

  config.pin_pwdn  = PWDN_GPIO_NUM;
  config.pin_reset = RESET_GPIO_NUM;

  config.xclk_freq_hz = 10000000;
  config.pixel_format = PIXFORMAT_JPEG;

  config.frame_size   = FRAMESIZE_QQVGA;
  config.jpeg_quality = 12;
  config.fb_count     = 1;
  config.fb_location  = CAMERA_FB_IN_PSRAM;
  config.grab_mode    = CAMERA_GRAB_LATEST;

  esp_err_t err = esp_camera_init(&config);
  if (err != ESP_OK) {
    Serial.printf("Camera init failed with error 0x%x\n", err);
    tftMsg("CAM FAIL");
    return;
  }

  Serial.println("Camera ready ✅");

  Serial.println("PIR warming up (30s)...");
  delay(30000);
  Serial.println("Ready!");
  tftMsg("READY", "MOVE=PHOTO");
}

// ---------------- LOOP ----------------
void loop() {
  // If waiting for YES, poll telegram
  if (awaitingYes) {
    if (millis() - awaitingSince > yesTimeout) {
      awaitingYes = false;
      Serial.println("⌛ YES timeout");
      tftMsg("TIMEOUT", "NO SPRAY");
      delay(1200);
      tftMsg("READY", "MOVE=PHOTO");
      return;
    }

    static unsigned long lastPoll = 0;
    if (millis() - lastPoll > 2000) {
      lastPoll = millis();
      Serial.println("Checking Telegram for YES...");
      if (checkTelegramForYes()) {
        Serial.println("✅ YES received!");
        tftMsg("THIS MY", "SHIT");
        sprayOnce();
        awaitingYes = false;
        delay(1500);
        tftMsg("READY", "MOVE=PHOTO");
      }
    }
    return;
  }

  // Normal mode: PIR triggers photo
  int motion = digitalRead(PIR_PIN);
  Serial.print("PIR: ");
  Serial.println(motion);

  if (motion == HIGH && millis() - lastMotionTime > motionCooldown) {
    lastMotionTime = millis();
    Serial.println("🚨 Motion detected!");

    tftMsg("SENDING", "PHOTO...");

    camera_fb_t * fb = esp_camera_fb_get();
    if (!fb) {
      Serial.println("Camera capture failed");
      tftMsg("CAPTURE", "FAILED");
      delay(1200);
      tftMsg("READY", "MOVE=PHOTO");
      return;
    }

    sendPhotoTelegram(fb);
    esp_camera_fb_return(fb);

    // Now wait for YES
    awaitingYes = true;
    awaitingSince = millis();
    tftMsg("REPLY", "YES TO SPRAY");
    Serial.println("Waiting for YES reply...");
  }

  delay(200);
}
