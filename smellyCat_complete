// ---------------- TELEGRAM: SEND PHOTO ----------------
void sendPhotoTelegram(camera_fb_t * fb) {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("WiFi not connected - cannot send Telegram.");
    return;
  }

  clientTCP.stop();
  clientTCP.setInsecure();
  clientTCP.setTimeout(20000);

  if (!clientTCP.connect("api.telegram.org", 443)) {
    Serial.println("Telegram connection failed");
    return;
  }

  String boundary = "ESP32CAMBOUNDARY";

  String head = "--" + boundary + "\r\n";
  head += "Content-Disposition: form-data; name=\"chat_id\"\r\n\r\n";
  head += chatID + "\r\n";
  head += "--" + boundary + "\r\n";
  head += "Content-Disposition: form-data; name=\"caption\"\r\n\r\n";
  head += "⚠️ Motion detected! Reply YES to spray.\r\n";
  head += "--" + boundary + "\r\n";
  head += "Content-Disposition: form-data; name=\"photo\"; filename=\"esp32.jpg\"\r\n";
  head += "Content-Type: image/jpeg\r\n\r\n";

  String tail = "\r\n--" + boundary + "--\r\n";

  uint32_t totalLen = head.length() + fb->len + tail.length();

  clientTCP.print("POST /bot" + botToken + "/sendPhoto HTTP/1.1\r\n");
  clientTCP.print("Host: api.telegram.org\r\n");
  clientTCP.print("Content-Length: " + String(totalLen) + "\r\n");
  clientTCP.print("Content-Type: multipart/form-data; boundary=" + boundary + "\r\n");
  clientTCP.print("Connection: close\r\n\r\n");

  clientTCP.print(head);
  clientTCP.write(fb->buf, fb->len);
  clientTCP.print(tail);

  Serial.println("📸 Photo upload request sent to Telegram...");

  // Skip headers
  while (clientTCP.connected()) {
    String line = clientTCP.readStringUntil('\n');
    if (line == "\r") break;
  }

  // Body
  String body = clientTCP.readString();
  Serial.println("Telegram response:");
  Serial.println(body);

  clientTCP.stop();
}

// ---------------- TELEGRAM: CHECK YES ----------------
bool checkTelegramForYes() {
  if (WiFi.status() != WL_CONNECTED) return false;

  clientTCP.stop();
  clientTCP.setInsecure();
  clientTCP.setTimeout(15000);

  if (!clientTCP.connect("api.telegram.org", 443)) {
    Serial.println("getUpdates connect failed");
    return false;
  }

  String url = "/bot" + botToken + "/getUpdates?timeout=0";
  if (lastUpdateId > 0) url += "&offset=" + String(lastUpdateId + 1);

  clientTCP.print("GET " + url + " HTTP/1.1\r\n");
  clientTCP.print("Host: api.telegram.org\r\n");
  clientTCP.print("Connection: close\r\n\r\n");

  // Skip headers
  while (clientTCP.connected()) {
    String line = clientTCP.readStringUntil('\n');
    if (line == "\r") break;
  }

  String body = clientTCP.readString();
  clientTCP.stop();

  // Update lastUpdateId (simple parse)
  int idx = 0;
  while (true) {
    int u = body.indexOf("\"update_id\":", idx);
    if (u < 0) break;
    int start = u + 12;
    while (start < (int)body.length() && body[start] == ' ') start++;
    int end = start;
    while (end < (int)body.length() && isDigit(body[end])) end++;
    long idVal = body.substring(start, end).toInt();
    if (idVal > lastUpdateId) lastUpdateId = idVal;
    idx = end;
  }

  // Look for YES (case-insensitive)
  String upper = body;
  upper.toUpperCase();

  // Only react to your chat id (basic check)
  if (upper.indexOf("\"CHAT\":{\"ID\":" + chatID) < 0 &&
      upper.indexOf("\"CHAT\": {\"ID\": " + chatID) < 0) {
    // still continue; Telegram JSON spacing varies
  }

  if (upper.indexOf("\"TEXT\":\"YES\"") >= 0) return true;

  return false;
}

